#
# Gameplay rule settings. Loaded at engine start alongside keybinds.oac.
#
# GAMEPLAY_FOREST_REGEN controls whether harvestable resource nodes (forests,
# gold, stone, ...) regenerate instead of vanishing once depleted:
#   off  - resource nodes are removed when fully gathered (original behaviour)
#   on   - depleted nodes remain and slowly regrow towards their original amount

set GAMEPLAY_FOREST_REGEN off
